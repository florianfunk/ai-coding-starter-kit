\documentclass{lichtengross-datenblatt-modern}

% Modernes Datenblatt nach Claude-Design-Briefing v2
% (daten/handoff/Datenblatt.html). Eine A4-Seite. Layout:
%   Masthead   — Logo links, Doc-Meta (2 Zeilen) rechts, Trennlinie
%   Hero       — Eyebrow + H1 + Article-Bar links | Quickfacts 3x2 rechts
%   Gallery    — 3 Bilder (1.4fr / 1fr / 1fr), feste Hoehe
%   Content    — Specs links (1.05fr), Beschreibung rechts (1fr)
%   Footer     — Firma+Stand | Energie-Skala | Version (Trennlinie oben)

\setfootercompany{(((meta.filiale | e)))}
\setfooterdate{(((meta.stand | e)))}
\setfooterrev{(((meta.revision | e)))}

\begin{document}

((# ═════ MASTHEAD ═════ #))
\noindent
\begin{minipage}[c]{\dimexpr 0.55\linewidth-3.85mm\relax}
  \vspace{0pt}
  ((* if logo_filename *))
  \includegraphics[height=3.5mm,keepaspectratio]{(((logo_filename)))}%
  ((* else *))
  {\displayfont\bfseries\fontsize{14pt}{16pt}\selectfont\addfontfeature{LetterSpace=4}\color{ink}\MakeUppercase{(((meta.brand_name | e)))}}%
  ((* endif *))
\end{minipage}\hspace{7mm}%
\begin{minipage}[c]{\dimexpr 0.45\linewidth-3.15mm\relax}\raggedleft
  {\monofont\fontsize{8.4pt}{12pt}\selectfont\addfontfeature{LetterSpace=10}\color{muted}\MakeUppercase{Produktdatenblatt}}\\
  {\monofont\fontsize{8.4pt}{12pt}\selectfont\addfontfeature{LetterSpace=10}\color{muted}\MakeUppercase{Seite 1/1}}
\end{minipage}

\vspace{1.4mm}{\color{ink}\hrule height 0.4pt}\vspace{4mm}

((# ═════ HERO: Linke Spalte (Eyebrow + Title + Hauptbild + Detail-Bilder) | Rechte Spalte (Artikelnr. + Quickfacts + Tech-Daten) ═════ #))
\noindent
\begin{minipage}[t]{\dimexpr 0.55\linewidth-3.85mm\relax}
  \vspace{0pt}
  ((* if produkt.eyebrow *))
  \noindent
  \begin{tikzpicture}[baseline=0pt, inner sep=0pt]
    \draw[accentdeep, line width=0.5pt] (0,0.4ex) -- (5mm,0.4ex);
  \end{tikzpicture}\hspace{1.5mm}%
  {\monofont\fontsize{8.4pt}{10pt}\selectfont\addfontfeature{LetterSpace=18}\color{accentdeep}\MakeUppercase{(((produkt.eyebrow | e)))}}
  \par\vspace{2.5mm}
  ((* endif *))
  {\displayfont\bfseries\fontsize{18pt}{20pt}\selectfont\color{ink}(((produkt.title | e)))}\\[0.6mm]
  ((* if produkt.title_accent *))
  {\displayfont\bfseries\fontsize{18pt}{20pt}\selectfont\color{accentdeep}(((produkt.title_accent | e)))}
  ((* endif *))

  % Hauptbild direkt unter dem Titel — proportional auf 85% der linken
  % Spaltenbreite skaliert, Originalseitenverhaeltnis bleibt erhalten,
  % linksbuendig, kein Rahmen.
  \par\vspace{5mm}
  ((* if figA_filename *))
  \noindent\includegraphics[width=0.85\linewidth,keepaspectratio]{(((figA_filename | e)))}
  ((* endif *))

  % Detail-Bilder (3 Stueck) unter dem Hauptbild — volle Spaltenbreite,
  % je 1/3 mit 3mm Spalt zwischen ihnen, randlos zugeschnitten.
  % Spaltenbreite jeweils: (linewidth - 2*3mm)/3
  \par\vspace{5mm}
  \newlength{\thirdw}\setlength{\thirdw}{\dimexpr (\linewidth - 6mm)/3\relax}
  \newlength{\xPosB}\setlength{\xPosB}{\dimexpr \thirdw + 3mm\relax}
  \newlength{\xPosC}\setlength{\xPosC}{\dimexpr 2\thirdw + 6mm\relax}
  \noindent\begin{tikzpicture}
    \def\hgt{24mm}
    ((* if figB_filename *))
    \begin{scope}
      \clip (0,0) rectangle (\thirdw,\hgt);
      \node[anchor=north west, inner sep=0pt] at (0,\hgt)
        {\includegraphics[width=\thirdw,height=\hgt,keepaspectratio=false]{(((figB_filename | e)))}};
    \end{scope}
    ((* endif *))
    ((* if figC_filename *))
    \begin{scope}
      \clip (\xPosB,0) rectangle (\dimexpr \xPosB + \thirdw\relax,\hgt);
      \node[anchor=north west, inner sep=0pt] at (\xPosB,\hgt)
        {\includegraphics[width=\thirdw,height=\hgt,keepaspectratio=false]{(((figC_filename | e)))}};
    \end{scope}
    ((* endif *))
    ((* if figD_filename *))
    \begin{scope}
      \clip (\xPosC,0) rectangle (\linewidth,\hgt);
      \node[anchor=north west, inner sep=0pt] at (\xPosC,\hgt)
        {\includegraphics[width=\thirdw,height=\hgt,keepaspectratio=false]{(((figD_filename | e)))}};
    \end{scope}
    ((* endif *))
    % Unsichtbarer Platzhalter sichert die Box-Hoehe auch bei fehlenden Bildern
    \path (0,0) rectangle (\linewidth,\hgt);
  \end{tikzpicture}

  % Zeichnung 1 (und optional Zeichnung 2 darunter) — volle Spaltenbreite,
  % proportional. Wenn beide vorhanden sind, untereinander mit 5mm Abstand.
  ((* if figE_filename *))
  \par\vspace{5mm}
  \noindent\includegraphics[width=\linewidth,height=32mm,keepaspectratio]{(((figE_filename | e)))}
  ((* endif *))
  ((* if figF_filename *))
  \par\vspace{5mm}
  \noindent\includegraphics[width=\linewidth,height=32mm,keepaspectratio]{(((figF_filename | e)))}
  ((* endif *))

  % Beschreibung direkt unter den Detail-Bildern — nutzt linke Spalte,
  % damit die Hoehe der Tech-Daten rechts ausbalanciert wird.
  % Ueberschrift nur, wenn auch Beschreibungstext vorhanden ist.
  ((* if paragraphs *))
  \par\vspace{5mm}
  \sectionhead{Anwendung \& Hinweise}{}
  ((* for para in paragraphs *))
  {\fontsize{8.6pt}{12pt}\selectfont\color{ink2}(((para | e)))}
  \par\vspace{2mm}
  ((* endfor *))
  ((* endif *))
\end{minipage}\hspace{7mm}%
\begin{minipage}[t]{\dimexpr 0.45\linewidth-3.15mm\relax}
  \vspace{0pt}
  % Artikelnummer rechts ausgerichtet, auf Hoehe der linken Eyebrow-Zeile —
  % gleiche Schriftgroesse wie "PRODUKTDATENBLATT" (8.4pt mono, muted).
  {\raggedleft\monofont\fontsize{8.4pt}{12pt}\selectfont\addfontfeature{LetterSpace=10}\color{muted}\MakeUppercase{Artikelnr.\ (((produkt.artikelnummer | e)))}\par}
  \vspace{1.4mm}
  % Energielabel direkt unter der Artikelnummer, ebenfalls rechtsbuendig.
  {\raggedleft\energyscale{(((meta.energy_class | e)))}\par}
  \vspace{3mm}

  % Quickfact-Grid 3x3 — nimmt die volle Breite der rechten Spalte ein.
  \setlength{\arrayrulewidth}{0.4pt}\arrayrulecolor{hair}
  \setlength{\tabcolsep}{1.5mm}
  \renewcommand{\arraystretch}{1.0}
  \noindent\begin{tabular}{|p{\dimexpr(\linewidth-1.6pt-9mm)/3\relax}|p{\dimexpr(\linewidth-1.6pt-9mm)/3\relax}|p{\dimexpr(\linewidth-1.6pt-9mm)/3\relax}|}
  \hline
  \quickfact{(((quickfacts[0].label | e)))}{(((quickfacts[0].value | e)))}{(((quickfacts[0].unit | e)))}{(((quickfacts[0].icon_image or "" | e)))} &
  \quickfact{(((quickfacts[1].label | e)))}{(((quickfacts[1].value | e)))}{(((quickfacts[1].unit | e)))}{(((quickfacts[1].icon_image or "" | e)))} &
  \quickfact{(((quickfacts[2].label | e)))}{(((quickfacts[2].value | e)))}{(((quickfacts[2].unit | e)))}{(((quickfacts[2].icon_image or "" | e)))} \\\hline
  \quickfact{(((quickfacts[3].label | e)))}{(((quickfacts[3].value | e)))}{(((quickfacts[3].unit | e)))}{(((quickfacts[3].icon_image or "" | e)))} &
  \quickfact{(((quickfacts[4].label | e)))}{(((quickfacts[4].value | e)))}{(((quickfacts[4].unit | e)))}{(((quickfacts[4].icon_image or "" | e)))} &
  \quickfact{(((quickfacts[5].label | e)))}{(((quickfacts[5].value | e)))}{(((quickfacts[5].unit | e)))}{(((quickfacts[5].icon_image or "" | e)))} \\\hline
  \quickfact{(((quickfacts[6].label | e)))}{(((quickfacts[6].value | e)))}{(((quickfacts[6].unit | e)))}{(((quickfacts[6].icon_image or "" | e)))} &
  \quickfact{(((quickfacts[7].label | e)))}{(((quickfacts[7].value | e)))}{(((quickfacts[7].unit | e)))}{(((quickfacts[7].icon_image or "" | e)))} &
  \quickfact{(((quickfacts[8].label | e)))}{(((quickfacts[8].value | e)))}{(((quickfacts[8].unit | e)))}{(((quickfacts[8].icon_image or "" | e)))} \\\hline
  \end{tabular}

  % Tech-Daten direkt unter den Quickfacts — gruppiert, kompakt.
  \par\vspace{10mm}
  \sectionhead{Technische Daten}{}
  ((* for group in spec_groups *))
  \specgroup{(((group.title | e)))}
  ((* for row in group.rows *))
  \specrow{(((row.label | e)))}{(((row.value | e)))}%
  ((* endfor *))
  ((* endfor *))

  % ACHTUNG-Hinweis unter den Tech-Daten — kleine, dezente Box rechts unten.
  ((* if warnung *))
  \par\vspace{6mm}
  \begin{tcolorbox}[
    enhanced, colback=warnbg, colframe=hair,
    boxrule=0.3pt, leftrule=1.5pt, sharp corners,
    borderline west={1.5pt}{0pt}{warnfg},
    boxsep=1.4mm, top=1.4mm, bottom=1.4mm, left=2.2mm, right=2.2mm,
  ]
  {\monofont\bfseries\fontsize{6.4pt}{7.4pt}\selectfont\addfontfeature{LetterSpace=14}\color{warnfg}\MakeUppercase{Achtung}}\par
  \vspace{0.8mm}
  {\fontsize{6.6pt}{8.4pt}\selectfont\color{ink2}(((warnung | e)))}
  \end{tcolorbox}
  ((* endif *))
\end{minipage}

\end{document}
