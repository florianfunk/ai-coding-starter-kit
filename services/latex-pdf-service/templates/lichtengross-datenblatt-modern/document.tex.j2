\documentclass{lichtengross-datenblatt-modern}

% Modernes Datenblatt nach Claude-Design-Briefing v2
% (daten/handoff/Datenblatt.html). Eine A4-Seite. Layout:
%   Masthead   — Logo links, Doc-Meta (2 Zeilen) rechts, Trennlinie
%   Hero       — Eyebrow + H1 + Article-Bar links | Quickfacts 3x2 rechts
%   Gallery    — 3 Bilder (1.4fr / 1fr / 1fr), feste Hoehe
%   Content    — Specs links (1.05fr), Beschreibung rechts (1fr)
%   Footer     — Firma+Stand | Energie-Skala | Version (Trennlinie oben)

\setfootercompany{(((meta.filiale | e)))}
\setfooterdate{(((meta.stand | e)))}
\setfooterrev{(((meta.revision | e)))}
\setfooterenergy{(((meta.energy_class | e)))}

\begin{document}

((# ═════ MASTHEAD ═════ #))
\noindent
\begin{minipage}[c]{0.55\linewidth}
  \vspace{0pt}
  ((* if logo_filename *))
  \includegraphics[height=7mm,keepaspectratio]{(((logo_filename)))}%
  ((* else *))
  {\displayfont\bfseries\fontsize{14pt}{16pt}\selectfont\addfontfeature{LetterSpace=4}\color{ink}\MakeUppercase{(((meta.brand_name | e)))}}%
  ((* endif *))
\end{minipage}\hfill
\begin{minipage}[c]{0.42\linewidth}\raggedleft
  {\monofont\fontsize{8.4pt}{12pt}\selectfont\addfontfeature{LetterSpace=10}\color{muted}\MakeUppercase{Produktdatenblatt}}\\
  {\monofont\fontsize{8.4pt}{12pt}\selectfont\addfontfeature{LetterSpace=10}\color{muted}\MakeUppercase{Seite 1/1}}
\end{minipage}

\vspace{1.4mm}{\color{ink}\hrule height 0.4pt}\vspace{4mm}

((# ═════ HERO: Linke Spalte (Eyebrow + Title + Article-Bar) | Rechte Spalte (Quickfacts) ═════ #))
\noindent
\begin{minipage}[t][28mm][s]{0.55\linewidth}
  \vspace{0pt}
  ((* if produkt.eyebrow *))
  \noindent
  \begin{tikzpicture}[baseline=0pt, inner sep=0pt]
    \draw[accentdeep, line width=0.5pt] (0,0.4ex) -- (5mm,0.4ex);
  \end{tikzpicture}\hspace{1.5mm}%
  {\monofont\fontsize{8.4pt}{10pt}\selectfont\addfontfeature{LetterSpace=18}\color{accentdeep}\MakeUppercase{(((produkt.eyebrow | e)))}}
  \par\vspace{2.5mm}
  ((* endif *))
  {\displayfont\bfseries\fontsize{18pt}{20pt}\selectfont\color{ink}(((produkt.title | e)))}\\[0.6mm]
  ((* if produkt.title_accent *))
  {\displayfont\bfseries\fontsize{18pt}{20pt}\selectfont\color{accentdeep}(((produkt.title_accent | e)))}
  ((* endif *))
  \vfill

  % Article-Bar — schwarze Box, ans Bottom der linken Spalte gepinnt.
  \noindent\colorbox{ink}{%
    \begin{minipage}{86mm}\vspace{1.6mm}\hspace{0pt}%
      \begin{tabular*}{86mm}{@{\extracolsep{\fill}}ll}
        {\monofont\fontsize{8.4pt}{10pt}\selectfont\addfontfeature{LetterSpace=16}\color{accent}\MakeUppercase{Artikelnr.}} &
        {\monofont\fontsize{10.5pt}{12pt}\selectfont\color{paper}(((produkt.artikelnummer | e)))}
      \end{tabular*}\vspace{1.6mm}%
    \end{minipage}%
  }
\end{minipage}\hfill
\begin{minipage}[t]{0.43\linewidth}
  \vspace{0pt}
  \setlength{\arrayrulewidth}{0.4pt}\arrayrulecolor{hair}
  \renewcommand{\arraystretch}{1.0}
  \noindent\begin{tabular}{|p{0.295\linewidth}|p{0.295\linewidth}|p{0.295\linewidth}|}
  \hline
  \quickfact{(((quickfacts[0].label | e)))}{(((quickfacts[0].value | e)))}{(((quickfacts[0].unit | e)))} &
  \quickfact{(((quickfacts[1].label | e)))}{(((quickfacts[1].value | e)))}{(((quickfacts[1].unit | e)))} &
  \quickfact{(((quickfacts[2].label | e)))}{(((quickfacts[2].value | e)))}{(((quickfacts[2].unit | e)))} \\\hline
  \quickfact{(((quickfacts[3].label | e)))}{(((quickfacts[3].value | e)))}{(((quickfacts[3].unit | e)))} &
  \quickfact{(((quickfacts[4].label | e)))}{(((quickfacts[4].value | e)))}{(((quickfacts[4].unit | e)))} &
  \quickfact{(((quickfacts[5].label | e)))}{(((quickfacts[5].value | e)))}{(((quickfacts[5].unit | e)))} \\\hline
  \end{tabular}
\end{minipage}

\vspace{10mm}

((# ═════ IMAGE GALLERY: 3 Bilder, 1.4fr / 1fr / 1fr, feste Hoehe ═════ #))
\noindent
\begin{minipage}[t]{0.43\linewidth}
  \vspace{0pt}
  ((* if figA_filename *))
  \fcolorbox{hairstrong}{paper}{%
    \parbox[c][24mm][c]{\linewidth-3pt}{\centering
      \includegraphics[width=94mm,height=23mm,keepaspectratio]{(((figA_filename | e)))}%
    }%
  }
  ((* else *))
  \fcolorbox{hairstrong}{paper}{%
    \parbox[c][24mm][c]{\linewidth-3pt}{\centering
      {\monofont\fontsize{9pt}{11pt}\selectfont\color{ink2}\MakeUppercase{Produktansicht}}\\[0.5mm]
      {\monofont\fontsize{7pt}{9pt}\selectfont\color{muted}\MakeUppercase{Strip auf Rolle}}
    }%
  }
  ((* endif *))
\end{minipage}\hfill
\begin{minipage}[t]{0.275\linewidth}
  \vspace{0pt}
  ((* if figB_filename *))
  \fcolorbox{hairstrong}{paper}{%
    \parbox[c][24mm][c]{\linewidth-3pt}{\centering
      \includegraphics[width=94mm,height=23mm,keepaspectratio]{(((figB_filename | e)))}%
    }%
  }
  ((* else *))
  \fcolorbox{hairstrong}{paper}{%
    \parbox[c][24mm][c]{\linewidth-3pt}{\centering
      {\monofont\fontsize{9pt}{11pt}\selectfont\color{ink2}\MakeUppercase{Detail}}
    }%
  }
  ((* endif *))
\end{minipage}\hfill
\begin{minipage}[t]{0.275\linewidth}
  \vspace{0pt}
  ((* if figC_filename *))
  \fcolorbox{hairstrong}{paper}{%
    \parbox[c][24mm][c]{\linewidth-3pt}{\centering
      \includegraphics[width=94mm,height=23mm,keepaspectratio]{(((figC_filename | e)))}%
    }%
  }
  ((* else *))
  \fcolorbox{hairstrong}{paper}{%
    \parbox[c][24mm][c]{\linewidth-3pt}{\centering
      {\monofont\fontsize{9pt}{11pt}\selectfont\color{ink2}\MakeUppercase{Anwendung}}
    }%
  }
  ((* endif *))
\end{minipage}

\vspace{10mm}


((# ═════ CONTENT: 2-Spalten — Specs links, Beschreibung rechts ═════ #))
\noindent
\begin{minipage}[t]{0.51\linewidth}
  \vspace{0pt}
  \sectionhead{Technische Daten}{01 / Spezifikation}

  ((* for group in spec_groups *))
  \specgroup{(((group.title | e)))}
  ((* for row in group.rows *))
  \specrow{(((row.label | e)))}{(((row.value | e)))}%
  ((* endfor *))
  ((* endfor *))
\end{minipage}\hfill
\begin{minipage}[t]{0.45\linewidth}
  \vspace{0pt}
  \sectionhead{Anwendung \& Hinweise}{02 / Beschreibung}

  ((* if produkt.lead *))
  {\displayfont\bfseries\fontsize{11pt}{13pt}\selectfont\color{ink}(((produkt.lead | e)))}
  \par\vspace{2.5mm}
  ((* endif *))

  ((* for para in paragraphs *))
  {\fontsize{9.5pt}{14pt}\selectfont\color{ink2}(((para | e)))}
  \par\vspace{2mm}
  ((* endfor *))

  ((* if warnung *))
  \vspace{1mm}
  \begin{tcolorbox}[
    enhanced, colback=warnbg, colframe=hair,
    boxrule=0.4pt, leftrule=2pt, sharp corners,
    borderline west={2pt}{0pt}{warnfg},
    boxsep=2mm, top=2mm, bottom=2mm, left=3mm, right=3mm,
  ]
  \noindent\begin{tabular*}{\linewidth}{@{}p{14mm}p{\linewidth-16mm}@{}}
    {\monofont\bfseries\fontsize{8pt}{10pt}\selectfont\addfontfeature{LetterSpace=16}\color{warnfg}\MakeUppercase{Achtung}} &
    {\fontsize{9pt}{12pt}\selectfont\color{ink2}(((warnung | e)))} \\
  \end{tabular*}
  \end{tcolorbox}
  ((* endif *))
\end{minipage}

\end{document}
